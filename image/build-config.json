{
  "arch": "x86_64",
  "distro": "alpine",
  "alpine": {
    "version": "3.23.0",
    "rootfsPackages": [
      "linux-virt",
      "rng-tools",
      "bash",
      "ca-certificates",
      "curl",
      "e2fsprogs",
      "git",
      "openssh",
      "build-base",
      "gcc",
      "g++",
      "make",
      "linux-headers",
      "pkgconf",
      "cmake",
      "ninja",
      "clang",
      "llvm",
      "lld",
      "gdb",
      "autoconf",
      "automake",
      "libtool",
      "nodejs",
      "npm",
      "python3",
      "py3-pip",
      "uv",
      "rust",
      "cargo"
    ]
  },
  "postBuild": {
    "commands": [
      "npm install -g pnpm",
      "pip install --break-system-packages conan"
    ]
  }
}
