{
  "arch": "x86_64",
  "distro": "alpine",
  "container": {
    "force": true,
    "runtime": "podman"
  },
  "alpine": {
    "version": "3.23.0",
    "rootfsPackages": [
      "linux-virt",
      "rng-tools",
      "bash",
      "ca-certificates",
      "curl",
      "e2fsprogs",
      "git",
      "jq",
      "openssh",
      "build-base",
      "gcc",
      "g++",
      "make",
      "linux-headers",
      "pkgconf",
      "cmake",
      "ninja",
      "clang",
      "llvm",
      "lld",
      "gdb",
      "autoconf",
      "automake",
      "libtool",
      "nodejs",
      "npm",
      "qemu-img",
      "qemu-system-x86_64",
      "python3",
      "py3-pip",
      "uv",
      "rust",
      "cargo"
    ]
  },
  "postBuild": {
    "copy": [
      {
        "src": "../tools/sage-fff/dist/sage-fff",
        "dest": "/usr/local/bin/sage-fff"
      }
    ],
    "commands": [
      "apk add --no-cache rust cargo && rustc -vV >/dev/null && sage-fff --help >/dev/null",
      "npm install -g pnpm @earendil-works/pi-coding-agent @earendil-works/gondolin",
      "pip install --break-system-packages 'conan==2.30.0'"
    ]
  }
}
