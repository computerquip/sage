#!/usr/bin/env sh
# User-facing Sage session manager.
#
# Creates a Herdr git worktree and starts the sandboxed pi launcher inside it.
# Also lists live Sage agents that Herdr can attach to.
set -eu

SCRIPT_PATH="$0"
if command -v readlink >/dev/null 2>&1; then
  RESOLVED_SCRIPT=$(readlink -f "$SCRIPT_PATH" 2>/dev/null || true)
  if [ -n "$RESOLVED_SCRIPT" ]; then
    SCRIPT_PATH="$RESOLVED_SCRIPT"
  fi
fi
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
SAGE_HOME="${SAGE_HOME:-$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)}"

export SAGE_HOME
export SAGE_QEMU_MACHINE_TYPE="${SAGE_QEMU_MACHINE_TYPE:-q35}"

if [ "${1:-}" = "__agent" ]; then
  shift

  if [ -z "${SAGE_IMAGE_DIR:-}" ]; then
    if [ -n "${SAGE_CACHE_DIR:-}" ]; then
      DEFAULT_SAGE_IMAGE_DIR="$SAGE_CACHE_DIR/gondolin-image"
    elif [ -n "${XDG_CACHE_HOME:-}" ]; then
      DEFAULT_SAGE_IMAGE_DIR="$XDG_CACHE_HOME/sage/gondolin-image"
    elif [ -n "${HOME:-}" ]; then
      DEFAULT_SAGE_IMAGE_DIR="$HOME/.cache/sage/gondolin-image"
    else
      DEFAULT_SAGE_IMAGE_DIR="$SAGE_HOME/.gondolin-image"
    fi

    if [ -d "$DEFAULT_SAGE_IMAGE_DIR" ]; then
      export SAGE_IMAGE_DIR="$DEFAULT_SAGE_IMAGE_DIR"
    fi
  fi

  if ! command -v pi >/dev/null 2>&1; then
    echo "error: 'pi' not found on PATH" >&2
    exit 1
  fi

  exec pi -e "$SAGE_HOME/packages/pi-sage-sandbox/index.ts" "$@"
fi

HERDR="${HERDR_BIN_PATH:-herdr}"
RUN_ID="$(date +%Y%m%d-%H%M%S)"
BRANCH="sage/$RUN_ID"
AGENT_NAME="${SAGE_AGENT_NAME:-sage-$RUN_ID}"
NO_ATTACH=false

if [ "${1:-}" = "--no-attach" ]; then
  NO_ATTACH=true
  shift
fi

default_image_dir() {
  if [ -n "${SAGE_CACHE_DIR:-}" ]; then
    printf '%s\n' "$SAGE_CACHE_DIR/gondolin-image"
  elif [ -n "${XDG_CACHE_HOME:-}" ]; then
    printf '%s\n' "$XDG_CACHE_HOME/sage/gondolin-image"
  elif [ -n "${HOME:-}" ]; then
    printf '%s\n' "$HOME/.cache/sage/gondolin-image"
  else
    printf '%s\n' "$SAGE_HOME/.gondolin-image"
  fi
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "sage: required command not found on PATH: $1" >&2
    exit 127
  fi
}

herdr_server_running() {
  [ "$("$HERDR" status server 2>/dev/null | sed -n '1p')" = "status: running" ]
}

ensure_herdr_server() {
  if herdr_server_running; then
    return
  fi

  if command -v setsid >/dev/null 2>&1; then
    nohup setsid "$HERDR" server >/tmp/sage-herdr-server.log 2>&1 </dev/null &
  else
    nohup "$HERDR" server >/tmp/sage-herdr-server.log 2>&1 </dev/null &
  fi

  i=0
  while ! herdr_server_running; do
    i=$((i + 1))
    if [ "$i" -ge 50 ]; then
      echo "sage: timed out waiting for herdr server to start" >&2
      echo "sage: see /tmp/sage-herdr-server.log" >&2
      exit 1
    fi
    sleep 0.1
  done
}

usage() {
  cat <<EOF
usage:
  sage [--no-attach] [pi args...]
                            create a new sage worktree and start a sandboxed pi agent
  sage list|history        list Sage worktrees for this repo
  sage attach [target]     attach/resume a Sage worktree; defaults to newest
  sage resume [target]     alias for attach
  sage remove [target]     remove a Sage worktree; defaults to newest
  sage install-image       download the prebuilt gondolin image
  sage update-image        same as install-image

Attach/remove targets:
  latest                   newest Sage worktree for this repo (default)
  <number>                 index from sage list
  <name|branch|pane_id|workspace_id|path>

Options:
  --no-attach              start/resume without attaching; print attach command

Environment:
  SAGE_HOME                sage install directory
  SAGE_AGENT_NAME          agent name override; default is sage-<timestamp>
  SAGE_QEMU_MACHINE_TYPE   QEMU machine override; default is q35
  SAGE_RELEASE_REPO        GitHub repo for image releases; default computerquip/sage
  SAGE_IMAGE_VERSION       GitHub release tag; default latest
  SAGE_IMAGE_INSTALL_DIR   install directory; default is user cache
  SAGE_CACHE_DIR           cache directory; default is XDG cache or ~/.cache/sage
  SAGE_IMAGE_URL           explicit image archive URL override
  SAGE_IMAGE_SHA256_URL    explicit sha256 URL override
EOF
}

list_sessions() {
  list_history
}

history_entries_json() {
  need_cmd jq
  ensure_herdr_server

  WT_JSON=$("$HERDR" worktree list --cwd "$PWD" --json)
  AGENTS_JSON=$("$HERDR" agent list)

  jq -n --argjson wt "$WT_JSON" --argjson agents "$AGENTS_JSON" '
    [
      $wt.result.worktrees[]
      | select((.branch // "") | startswith("sage/"))
      | . as $worktree
      | (($agents.result.agents // [])
          | map(select(
              (.workspace_id == ($worktree.open_workspace_id // ""))
              or (.cwd == $worktree.path)
            ))
          | .[0]) as $agent
      | {
          name: ((.branch // "") | sub("^sage/"; "sage-") | gsub("/"; "-")),
          branch: (.branch // ""),
          path: (.path // ""),
          workspace_id: (.open_workspace_id // ""),
          status: (if $agent then "LIVE" else "STOPPED" end),
          pane_id: ($agent.pane_id // ""),
          agent_name: ($agent.name // "")
        }
    ]
  '
}

list_history() {
  entries=$(history_entries_json)

  if command -v column >/dev/null 2>&1; then
    printf '%s' "$entries" | jq -r '
      if length == 0 then
        "No Sage worktrees found for this repo."
      else
        (["#", "STATUS", "NAME", "TARGET", "WORKSPACE", "BRANCH", "CWD"] | @tsv),
        (to_entries[] | [(.key + 1), .value.status, .value.name, .value.pane_id, .value.workspace_id, .value.branch, .value.path] | @tsv)
      end
    ' | column -t -s "$(printf '\t')"
  else
    printf '%s' "$entries" | jq -r '
      if length == 0 then
        "No Sage worktrees found for this repo."
      else
        (["#", "STATUS", "NAME", "TARGET", "WORKSPACE", "BRANCH", "CWD"] | @tsv),
        (to_entries[] | [(.key + 1), .value.status, .value.name, .value.pane_id, .value.workspace_id, .value.branch, .value.path] | @tsv)
      end
    '
  fi
}

resolve_history_field() {
  target="${1:-latest}"
  field="$2"
  entries="$3"

  if [ "$target" = "latest" ]; then
    printf '%s' "$entries" | jq -r --arg field "$field" '
      if length == 0 then empty else .[-1][$field] // empty end
    '
  else
    case "$target" in
      *[!0-9]*)
        printf '%s' "$entries" | jq -r --arg target "$target" --arg field "$field" '
          map(select(
            .name == $target
            or .branch == $target
            or .workspace_id == $target
            or .pane_id == $target
            or .path == $target
          ))
          | if length == 0 then empty else .[0][$field] // empty end
        '
        ;;
      *)
        printf '%s' "$entries" | jq -r --argjson idx "$target" --arg field "$field" '
          .[$idx - 1][$field] // empty
        '
        ;;
    esac
  fi
}

attach_session() {
  target="${1:-latest}"
  shift || true
  resume_session "$target" "$@"
  if [ -n "${PANE_ID:-}" ]; then
    echo "sage: attaching to $PANE_ID" >&2
    exec "$HERDR" agent attach "$PANE_ID"
  fi
}

remove_session() {
  target="${1:-latest}"
  entries=$(history_entries_json)
  workspace_id=$(resolve_history_field "$target" workspace_id "$entries")
  name=$(resolve_history_field "$target" name "$entries")
  branch=$(resolve_history_field "$target" branch "$entries")
  pane_id=$(resolve_history_field "$target" pane_id "$entries")

  if [ -z "$name" ] || [ -z "$branch" ]; then
    echo "sage: no Sage worktree matches '$target'" >&2
    exit 1
  fi

  if [ -z "$workspace_id" ]; then
    OPEN_JSON=$("$HERDR" worktree open --cwd "$PWD" --branch "$branch" --no-focus --json)
    workspace_id=$(printf '%s' "$OPEN_JSON" | jq -r '.result.workspace.workspace_id // .result.workspace_id // .result.root_pane.workspace_id // empty')
  fi

  if [ -z "$workspace_id" ]; then
    echo "sage: could not resolve workspace for $branch" >&2
    exit 1
  fi

  echo "sage: removing ${name:-$target} (${pane_id:-unknown}, workspace $workspace_id)" >&2
  "$HERDR" worktree remove --workspace "$workspace_id" --force --json >/dev/null
  echo "sage: removed workspace $workspace_id"
}

has_session_arg() {
  for arg in "$@"; do
    case "$arg" in
      --continue|-c|--resume|-r|--session|--session=*|--session-id|--session-id=*|--fork|--fork=*)
        return 0
        ;;
    esac
  done
  return 1
}

start_agent() {
  ws_id="$1"
  wt_path="$2"
  agent_name="$3"
  shift 3

  has_provider=false
  for arg in "$@"; do
    if [ "$arg" = "--provider" ]; then
      has_provider=true
      break
    fi
  done

  if [ "$has_provider" = false ]; then
    set -- --provider openai-codex "$@"
  fi

  set +e
  if [ -n "${SSH_AUTH_SOCK:-}" ]; then
    AGENT_JSON=$("$HERDR" agent start "$agent_name" --workspace "$ws_id" --cwd "$wt_path" --env "SSH_AUTH_SOCK=$SSH_AUTH_SOCK" -- "$SAGE_HOME/bin/sage" __agent "$@")
    AGENT_STATUS=$?
  else
    AGENT_JSON=$("$HERDR" agent start "$agent_name" --workspace "$ws_id" --cwd "$wt_path" -- "$SAGE_HOME/bin/sage" __agent "$@")
    AGENT_STATUS=$?
  fi
  set -e

  if [ "$AGENT_STATUS" -ne 0 ]; then
    echo "$AGENT_JSON" >&2
    exit "$AGENT_STATUS"
  fi

  AGENT_NAME_OUT=$(printf '%s' "$AGENT_JSON" | jq -r '.result.agent.name // empty')
  PANE_ID=$(printf '%s' "$AGENT_JSON" | jq -r '.result.agent.pane_id // empty')
  TERMINAL_ID=$(printf '%s' "$AGENT_JSON" | jq -r '.result.agent.terminal_id // empty')

  echo "sage: started ${AGENT_NAME_OUT:-$agent_name}"
  echo "sage: workspace $ws_id, pane ${PANE_ID:-unknown}, cwd $wt_path"
  if [ -n "$PANE_ID" ]; then
    echo "sage: attach with: herdr agent attach $PANE_ID"
  elif [ -n "$TERMINAL_ID" ]; then
    echo "sage: attach with: herdr agent attach $TERMINAL_ID"
  else
    echo "sage: attach with: herdr agent attach $agent_name"
  fi
}

resume_session() {
  target="${1:-latest}"
  shift || true

  entries=$(history_entries_json)
  name=$(resolve_history_field "$target" name "$entries")
  branch=$(resolve_history_field "$target" branch "$entries")
  wt_path=$(resolve_history_field "$target" path "$entries")
  ws_id=$(resolve_history_field "$target" workspace_id "$entries")
  pane_id=$(resolve_history_field "$target" pane_id "$entries")

  if [ -z "$name" ] || [ -z "$branch" ] || [ -z "$wt_path" ]; then
    echo "sage: no Sage worktree matches '$target'" >&2
    exit 1
  fi

  if [ -n "$pane_id" ]; then
    if [ "$NO_ATTACH" = true ]; then
      echo "sage: $name is already live"
      echo "sage: attach with: herdr agent attach $pane_id"
      return
    else
      echo "sage: $name is already live; attaching to $pane_id" >&2
      exec "$HERDR" agent attach "$pane_id"
    fi
  fi

  if [ -z "$ws_id" ]; then
    OPEN_JSON=$("$HERDR" worktree open --cwd "$PWD" --branch "$branch" --no-focus --json)
    ws_id=$(printf '%s' "$OPEN_JSON" | jq -r '.result.workspace.workspace_id // .result.workspace_id // .result.root_pane.workspace_id // empty')
    wt_path=$(printf '%s' "$OPEN_JSON" | jq -r '.result.worktree.path // .result.workspace.worktree.checkout_path // empty')
  fi

  if [ -z "$ws_id" ] || [ -z "$wt_path" ]; then
    echo "sage: could not open worktree for $branch" >&2
    exit 1
  fi

  if has_session_arg "$@"; then
    start_agent "$ws_id" "$wt_path" "$name" "$@"
  else
    start_agent "$ws_id" "$wt_path" "$name" --continue "$@"
  fi

  if [ "$NO_ATTACH" = false ] && [ -n "${PANE_ID:-}" ]; then
    echo "sage: attaching to $PANE_ID" >&2
    exec "$HERDR" agent attach "$PANE_ID"
  fi
}

image_arch() {
  case "$(uname -m)" in
    x86_64|amd64)
      printf '%s\n' x86_64
      ;;
    aarch64|arm64)
      printf '%s\n' aarch64
      ;;
    *)
      echo "sage: unsupported image architecture: $(uname -m)" >&2
      exit 1
      ;;
  esac
}

install_image() {
  need_cmd curl
  need_cmd tar
  need_cmd mktemp

  arch=$(image_arch)
  repo="${SAGE_RELEASE_REPO:-computerquip/sage}"
  version="${SAGE_IMAGE_VERSION:-latest}"
  asset="sage-gondolin-image-$arch.tar.gz"

  if [ "$version" = "latest" ]; then
    image_url="https://github.com/$repo/releases/latest/download/$asset"
  else
    image_url="https://github.com/$repo/releases/download/$version/$asset"
  fi
  image_url="${SAGE_IMAGE_URL:-$image_url}"

  if [ -n "${SAGE_IMAGE_SHA256_URL:-}" ]; then
    sha_url="$SAGE_IMAGE_SHA256_URL"
  else
    sha_url="$image_url.sha256"
  fi

  image_dir="${SAGE_IMAGE_INSTALL_DIR:-$(default_image_dir)}"
  tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/sage-image.XXXXXX")
  trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

  if [ -z "${SAGE_IMAGE_URL:-}" ] && command -v gh >/dev/null 2>&1; then
    echo "sage: downloading GitHub release assets from $repo ($version)" >&2
    if [ "$version" = "latest" ]; then
      gh release download --repo "$repo" --dir "$tmp_dir" --pattern "$asset" --pattern "$asset.sha256" --clobber
    else
      gh release download "$version" --repo "$repo" --dir "$tmp_dir" --pattern "$asset" --pattern "$asset.sha256" --clobber
    fi
  else
    echo "sage: downloading $image_url" >&2
    curl -fsSL --retry 3 --output "$tmp_dir/$asset" "$image_url"

    echo "sage: downloading $sha_url" >&2
    curl -fsSL --retry 3 --output "$tmp_dir/$asset.sha256" "$sha_url"
  fi

  (
    cd "$tmp_dir"
    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum -c "$asset.sha256"
    elif command -v shasum >/dev/null 2>&1; then
      shasum -a 256 -c "$asset.sha256"
    else
      echo "sage: required command not found on PATH: sha256sum or shasum" >&2
      exit 127
    fi
  )

  rm -rf "$tmp_dir/extract"
  mkdir -p "$tmp_dir/extract"
  tar -xzf "$tmp_dir/$asset" -C "$tmp_dir/extract"

  if [ ! -f "$tmp_dir/extract/manifest.json" ] || [ ! -f "$tmp_dir/extract/rootfs.ext4" ]; then
    echo "sage: downloaded image archive does not look like a gondolin image" >&2
    exit 1
  fi

  rm -rf "$image_dir.tmp"
  mkdir -p "$(dirname "$image_dir")"
  mv "$tmp_dir/extract" "$image_dir.tmp"
  rm -rf "$image_dir"
  mv "$image_dir.tmp" "$image_dir"

  echo "sage: installed gondolin image to $image_dir" >&2
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  list|sessions)
    shift
    if [ "$#" -ne 0 ]; then
      echo "sage: list takes no arguments" >&2
      exit 2
    fi
    list_sessions
    exit 0
    ;;
  history)
    shift
    if [ "$#" -ne 0 ]; then
      echo "sage: history takes no arguments" >&2
      exit 2
    fi
    list_history
    exit 0
    ;;
  attach)
    shift
    if [ "${1:-}" = "--no-attach" ]; then
      NO_ATTACH=true
      shift
    fi
    if [ "$#" -gt 1 ]; then
      echo "sage: attach accepts at most one target" >&2
      exit 2
    fi
    attach_session "${1:-latest}"
    ;;
  resume)
    shift
    if [ "${1:-}" = "--no-attach" ]; then
      NO_ATTACH=true
      shift
    fi
    target="${1:-latest}"
    if [ "$#" -gt 0 ]; then
      shift
    fi
    resume_session "$target" "$@"
    exit 0
    ;;
  remove|rm)
    shift
    if [ "$#" -gt 1 ]; then
      echo "sage: remove accepts at most one target" >&2
      exit 2
    fi
    remove_session "${1:-latest}"
    exit 0
    ;;
  install-image|update-image)
    shift
    if [ "$#" -ne 0 ]; then
      echo "sage: install-image takes no arguments" >&2
      exit 2
    fi
    install_image
    exit 0
    ;;
esac

need_cmd "$HERDR"
need_cmd jq
ensure_herdr_server

echo "sage: creating worktree on branch $BRANCH" >&2

if [ -n "${HERDR_WORKSPACE_ID:-}" ]; then
  WS_JSON=$("$HERDR" worktree create --workspace "$HERDR_WORKSPACE_ID" --branch "$BRANCH" --no-focus --json)
else
  WS_JSON=$("$HERDR" worktree create --cwd "$PWD" --branch "$BRANCH" --no-focus --json)
fi

WS_ID=$(printf '%s' "$WS_JSON" | jq -r '.result.workspace.workspace_id // .result.workspace_id // .result.root_pane.workspace_id // .workspace_id // .workspace.id // empty')
WT_PATH=$(printf '%s' "$WS_JSON" | jq -r '.result.worktree.path // .result.workspace.worktree.checkout_path // empty')

if [ -z "$WS_ID" ] || [ -z "$WT_PATH" ]; then
  echo "sage: could not extract workspace id or worktree path from 'worktree create --json' output:" >&2
  echo "$WS_JSON" >&2
  echo "sage: inspect the JSON above and fix the jq filters in $0" >&2
  exit 1
fi

echo "sage: launching sandboxed pi agent in workspace $WS_ID" >&2

start_agent "$WS_ID" "$WT_PATH" "$AGENT_NAME" "$@"

if [ "$NO_ATTACH" = false ] && [ -n "${PANE_ID:-}" ]; then
  echo "sage: attaching to $PANE_ID" >&2
  exec "$HERDR" agent attach "$PANE_ID"
fi
